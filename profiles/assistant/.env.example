# assistant profile — environment variables
# Copy to ~/.hermes/profiles/assistant/.env and replace FILL_IN.

# --- Required ---
ANTHROPIC_API_KEY=FILL_IN

# --- Optional: Telegram personal bot ---
# Create a bot at @BotFather, paste the token here.
# Each profile MUST use a distinct bot. Reusing the same token across
# profiles will cause the second gateway to refuse to start.
# TELEGRAM_BOT_TOKEN=FILL_IN

# --- Optional: weather, calendar integrations ---
# OPENWEATHER_API_KEY=FILL_IN
