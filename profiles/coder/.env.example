# coder profile — environment variables
# Copy this to ~/.hermes/profiles/coder/.env and replace FILL_IN values.
# DO NOT commit the populated .env to git.

# --- Required: at least one model provider ---
ANTHROPIC_API_KEY=FILL_IN

# --- Optional: alternate providers (leave empty if unused) ---
# OPENROUTER_API_KEY=FILL_IN
# OPENAI_API_KEY=FILL_IN
# GEMINI_API_KEY=FILL_IN
# DEEPSEEK_API_KEY=FILL_IN

# --- Optional: web search providers (auxiliary) ---
# BRAVE_SEARCH_API_KEY=FILL_IN
# EXA_API_KEY=FILL_IN

# --- Channels: this profile is CLI-only by default. Leave channel tokens unset. ---
