# community-bot profile — environment variables
# Copy to ~/.hermes/profiles/community-bot/.env and replace FILL_IN.

# --- Required ---
ANTHROPIC_API_KEY=FILL_IN

# --- Channels: at least one required for the bot to be useful ---
# Get from @BotFather on Telegram. Must be a DIFFERENT bot from the
# one used in the assistant profile, or the gateway will refuse to start.
# TELEGRAM_BOT_TOKEN=FILL_IN

# Discord application bot token from https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=FILL_IN

# --- Optional: alternate cheap providers for fallback ---
# OPENROUTER_API_KEY=FILL_IN     # access to Haiku alternatives
# DEEPSEEK_API_KEY=FILL_IN
