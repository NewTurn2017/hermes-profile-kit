# research profile — environment variables
# Copy to ~/.hermes/profiles/research/.env and replace FILL_IN.

# --- Required ---
ANTHROPIC_API_KEY=FILL_IN

# --- Recommended: dedicated search providers (better than scraping) ---
# BRAVE_SEARCH_API_KEY=FILL_IN
# EXA_API_KEY=FILL_IN
# TAVILY_API_KEY=FILL_IN

# --- Optional: paper/PDF retrieval ---
# SEMANTIC_SCHOLAR_API_KEY=FILL_IN

# --- Channels: CLI-only by default. ---
